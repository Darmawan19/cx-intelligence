# Shopee CX Intelligence Tool — Environment Config
# Copy this file to .env and fill in your values

ANTHROPIC_API_KEY=your_api_key_here

# Model config (cost optimization)
# Use haiku for batch classification, sonnet for synthesis
CLASSIFY_MODEL=claude-haiku-4-5-20251001
SYNTHESIZE_MODEL=claude-sonnet-4-20250514

# Scraping config
APP_ID=com.shopee.id
SCRAPE_COUNT=600
SCRAPE_LANG=id
SCRAPE_COUNTRY=id

# Quality gate threshold (re-prompt if error rate above this)
QUALITY_GATE_THRESHOLD=0.15
QUALITY_SAMPLE_SIZE=50
